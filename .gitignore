# Root .gitignore for migration_platformss project

# --- Backend / Python ---
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/.venv/
**/venv/
**/env/
**/ENV/
**/.pytest_cache/

# Databases & local state
backend/database.db
backend/migration.db
backend/uploads/
backend/outputs/

# Environment variables
**/.env
**/.env.local
**/.env.*.local

# --- Frontend / Node ---
**/node_modules/
frontend/dist/
frontend/dist-ssr/

# Logs
*.log
frontend/err.log
frontend/vite_err.log
frontend/vite_out.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS / IDEs ---
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
